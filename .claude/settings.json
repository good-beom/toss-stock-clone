{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; [[ \"$FILE\" == *.ts || \"$FILE\" == *.tsx ]] && npx prettier --write \"$FILE\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; [[ \"$FILE\" == *.ts || \"$FILE\" == *.tsx ]] && npx eslint \"$FILE\" --fix --quiet 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'git push.*--force|git push.*-f|git reset --hard|rm -rf /' && exit 2 || exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CHANGED=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' '); [ \"$CHANGED\" -gt 4 ] && echo '{\"decision\": \"block\", \"reason\": \"변경 파일이 4개 초과입니다. 커밋 후 계속하세요.\"}' || exit 0"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs input\" with title \"Claude Code\"' 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
